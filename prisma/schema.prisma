generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ───────────────────────────────────────────────

enum Role {
  OWNER              // Benjy, Nitay — full access to everything
  GM                 // Suzanne — full access
  ADMIN              // Legacy admin role — full access
  PRODUCTION_MANAGER // Legacy — use SENIOR_PLANT_MANAGER
  SENIOR_PLANT_MANAGER // Darrin — full access, separate from regular plant roles
  ACCOUNTING         // Full access
  ESTIMATOR          // Everything except dashboard — Mary Bitting
  CSR                // Everything except accounting/dashboard/executive features
  SALES_REP          // Quotes + their own customers only, job status tracking
  SALES_MANAGER      // Same as SALES_REP but with team view
  SHIPPING           // Shipping page only
  OPERATOR           // Plant floor timer only — nothing else
  CUSTOMER           // Customer portal only
}

enum JobStatus {
  QUOTE
  ARTWORK_RECEIVED
  STRUCTURAL_DESIGN
  PROOFING
  CUSTOMER_APPROVAL
  PREPRESS
  PLATING
  MATERIALS_ORDERED
  MATERIALS_RECEIVED
  SCHEDULED
  PRINTING
  COATING_FINISHING
  DIE_CUTTING
  GLUING_FOLDING
  QA
  PACKED
  SHIPPED
  DELIVERED
  INVOICED
}

enum StageStatus {
  NOT_STARTED
  IN_PROGRESS
  BLOCKED
  COMPLETE
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum ProofStatus {
  PENDING
  SENT
  APPROVED
  REJECTED
  REVISION_REQUESTED
}

enum ShipmentStatus {
  PREPARING
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  EXCEPTION
}

enum AlertType {
  PROOF_OVERDUE
  MATERIAL_SHORTAGE
  JOB_PAST_DUE
  STAGE_BLOCKED
  QA_HOLD
  SHIPMENT_DELAYED
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

// ─── USERS & AUTH ────────────────────────────────────────

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  passwordHash   String
  role           Role     @default(CUSTOMER)
  avatarUrl      String?
  companyId      String?
  company        Company? @relation(fields: [companyId], references: [id])
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  assignedJobsCsr    Job[]    @relation("JobCsr")
  assignedJobsSales  Job[]    @relation("JobSales")
  assignedJobsProd   Job[]    @relation("JobProduction")
  stageUpdates       JobStageUpdate[]
  proofApprovals     ProofApproval[]
  comments           Comment[]
  activityLogs       ActivityLog[]
  alerts             Alert[]
  timeEntries        TimeEntry[]

  @@index([email])
  @@index([companyId])
}

model InviteToken {
  id         String    @id @default(cuid())
  email      String
  token      String    @unique
  role       Role      @default(CUSTOMER)
  companyId  String?
  expiresAt  DateTime
  usedAt     DateTime?
  createdBy  String
  createdAt  DateTime  @default(now())

  @@index([token])
}

// ─── COMPANIES & CUSTOMERS ───────────────────────────────

model Company {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  type        String    @default("customer") // "internal" or "customer"
  website     String?
  address     String?
  city        String?
  state       String?
  zip         String?
  phone       String?
  industry    String?
  isActive    Boolean   @default(true)
  users       User[]
  contacts    Contact[]
  orders      Order[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([slug])
}

model Contact {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  email       String?
  phone       String?
  title       String?
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([companyId])
}

// ─── ORDERS & JOBS ───────────────────────────────────────

model Order {
  id              String    @id @default(cuid())
  orderNumber     String    @unique
  poNumber        String?
  companyId       String
  company         Company   @relation(fields: [companyId], references: [id])
  status          JobStatus @default(QUOTE)
  priority        Priority  @default(NORMAL)
  requestedShipDate DateTime?
  dueDate         DateTime?
  notes           String?
  totalAmount     Float?
  items           OrderItem[]
  jobs            Job[]
  shipments       Shipment[]
  documents       Document[]
  comments        Comment[]
  activityLogs    ActivityLog[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([companyId])
  @@index([orderNumber])
  @@index([status])
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sku         String?
  description String
  quantity    Int
  unitPrice   Float?
  job         Job?
  createdAt   DateTime @default(now())

  @@index([orderId])
}

model Job {
  id               String    @id @default(cuid())
  jobNumber        String    @unique
  orderId          String
  order            Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItemId      String?   @unique
  orderItem        OrderItem? @relation(fields: [orderItemId], references: [id])
  // Link back to the originating quote request (if any). Lets the job ticket
  // surface the full QR menu (proofs, foil, mailing, etc.) without duplicating
  // 40+ columns here. Plain String? — no Prisma relation — so the QR can be
  // queried lazily when needed.
  quoteRequestId   String?
  name             String
  description      String?
  status           JobStatus @default(QUOTE)
  priority         Priority  @default(NORMAL)
  quantity         Int
  dueDate          DateTime?
  requestedShipDate DateTime?
  plantLocation    String?
  csrId            String?
  csr              User?     @relation("JobCsr", fields: [csrId], references: [id])
  salesRepId       String?
  salesRep         User?     @relation("JobSales", fields: [salesRepId], references: [id])
  productionOwnerId String?
  productionOwner  User?     @relation("JobProduction", fields: [productionOwnerId], references: [id])
  stages           JobStage[]
  proofs           Proof[]
  materialReqs     MaterialRequirement[]
  schedules        ProductionSchedule[]
  alerts           Alert[]
  timeEntries      TimeEntry[]
  purchases        PurchaseFlag[]
  lineItems        JobLineItem[]
  pressRuns        PressRun[]
  productType      ProductType @default(FOLDING_CARTON)
  quotedPrice      Float?    // price from the approved quote
  estimatedCost    Float?    // internal cost estimate
  actualCost       Float?    // actual cost after completion

  // ─── Job Ticket Fields (matching C&D physical form) ────
  jobType          String?   // NEW_ORDER, EXACT_REPRINT, REPRINT_WITH_CHANGES, REPRINT_NEW_FILE
  lastJobNumber    String?   // reference to previous job for reprints
  customerPO       String?
  estimateNumber   String?
  repName          String?
  contactName      String?
  numPages         Int?

  // Stock & Materials
  stockDescription String?
  fscCertified     Boolean   @default(false)
  blanketNumber    String?
  dieNumber        String?
  paperSource      String?   // "on_hand" | "order_new" | "customer_supplied"

  // Size Specs
  flatSizeWidth    Float?
  flatSizeHeight   Float?
  finishedWidth    Float?
  finishedHeight   Float?
  inkFront         String?   // e.g. "4" for CMYK, "4+1PMS"
  inkBack          String?
  varnish          String?   // e.g. "AQ Gloss", "UV Spot", "Soft Touch"
  coating          String?

  // Press Info
  pressAssignment  String?   // which press machine
  pressFormat      String?
  imposition       String?
  numberUp         Int?
  runningSize      String?
  makeReadyCount   Int?
  firstPassCount   Int?
  finalPressCount  Int?
  pressmanInitials String?
  pressCheck       Boolean   @default(false)
  ledInk           Boolean   @default(false)

  // Bindery Instructions (checkboxes from job ticket)
  binderyScore     Boolean   @default(false)
  binderyPerf      Boolean   @default(false)
  binderyDrill     Boolean   @default(false)
  binderyPad       Boolean   @default(false)
  binderyFold      Boolean   @default(false)
  binderyCount     Boolean   @default(false)
  binderyStitch    Boolean   @default(false)
  binderyCollate   Boolean   @default(false)
  binderyPockets   Boolean   @default(false)
  binderyGlue      Boolean   @default(false)
  binderyWrap      Boolean   @default(false)
  binderyOther     String?
  binderyNotes     String?

  // Delivery
  deliveryQty      Int?
  deliveryPackaging String?
  deliveryTo       String?

  // Samples
  samplesRequired  Boolean   @default(false)
  samplesTo        String?
  samplesChecked   Boolean   @default(false)

  // Tracking
  aaCharges        Float?
  vendorInfo       String?
  proofDate        DateTime?
  enteredDate      DateTime?
  pressNotes       String?
  paymentNotes     String?
  prepressNotes    String?
  // General Notes — cross-department critical info (deadlines, mask pin#s,
  // quality warnings). CSRs were cramming notes into random margins because
  // department-specific notes are only visible to one team. This field is
  // rendered prominently at the top of the job ticket + print view.
  generalNotes     String?

  // Labor Tracking
  estimatedHours   Float?    // total estimated labor hours for this job
  actualHours      Float?    // calculated from TimeEntry records
  laborCostRate    Float?    // $/hour for labor cost calculation

  // Cover type
  softCover        Boolean   @default(false)
  plusCover         Boolean   @default(false)
  hasBleeds        Boolean   @default(false)

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([orderId])
  @@index([status])
  @@index([dueDate])
  @@index([jobNumber])
}

model JobStage {
  id           String      @id @default(cuid())
  jobId        String
  job          Job         @relation(fields: [jobId], references: [id], onDelete: Cascade)
  stage        JobStatus
  status       StageStatus @default(NOT_STARTED)
  ownerId      String?
  targetDate   DateTime?
  actualDate   DateTime?
  notes        String?
  blockerReason String?
  sortOrder    Int         @default(0)
  updates      JobStageUpdate[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([jobId, stage])
  @@index([jobId])
}

model JobStageUpdate {
  id          String   @id @default(cuid())
  stageId     String
  stage       JobStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  fromStatus  StageStatus
  toStatus    StageStatus
  notes       String?
  createdAt   DateTime @default(now())
}

// ─── PROOFING ────────────────────────────────────────────

model Proof {
  id            String      @id @default(cuid())
  jobId         String
  job           Job         @relation(fields: [jobId], references: [id], onDelete: Cascade)
  version       Int         @default(1)
  fileUrl       String?
  fileName      String?
  status        ProofStatus @default(PENDING)
  sentDate      DateTime?   // when pre-press created/uploaded the proof
  notes         String?
  approvals     ProofApproval[]
  // Pre-press → Sales → Customer → Production handoff (Mary workflow review):
  // PENDING = pre-press uploaded, awaiting sales to send to customer
  // SENT_TO_CUSTOMER (tracked via sentToCustomerAt) = sales sent proof to customer
  // APPROVED = customer signed off → triggers production alert
  deliveryMethod     String?     // "email" | "physical"
  sentToCustomerAt   DateTime?   // when sales sent to the customer
  sentToCustomerById String?     // which sales rep sent it
  customerApprovedAt DateTime?   // when customer approved (alert fires at this moment)
  customerRejectedAt DateTime?
  productionAlertSentAt DateTime?  // when we notified production — idempotency marker

  createdAt     DateTime    @default(now())

  @@index([jobId])
}

model ProofApproval {
  id          String      @id @default(cuid())
  proofId     String
  proof       Proof       @relation(fields: [proofId], references: [id], onDelete: Cascade)
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  status      ProofStatus
  comments    String?
  createdAt   DateTime    @default(now())
}

// ─── MATERIALS & INVENTORY ───────────────────────────────

model Material {
  id           String    @id @default(cuid())
  name         String
  sku          String?   @unique
  category     String?   // substrate, ink, coating, adhesive, etc.
  description  String?
  unit         String    @default("sheets") // sheets, lbs, gallons, etc.
  reorderPoint Int       @default(0)
  vendor       String?
  lots         InventoryLot[]
  requirements MaterialRequirement[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model InventoryLot {
  id           String   @id @default(cuid())
  materialId   String
  material     Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  lotNumber    String?
  quantityOnHand Int    @default(0)
  quantityAllocated Int @default(0)
  quantityOrdered Int   @default(0)
  expectedArrival DateTime?
  vendor       String?
  cost         Float?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([materialId])
}

model MaterialRequirement {
  id           String   @id @default(cuid())
  jobId        String
  job          Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  materialId   String
  material     Material @relation(fields: [materialId], references: [id])
  quantityNeeded Int
  quantityAllocated Int @default(0)
  isShort      Boolean  @default(false)
  notes        String?
  createdAt    DateTime @default(now())

  @@index([jobId])
  @@index([materialId])
}

model PurchaseOrder {
  id           String   @id @default(cuid())
  poNumber     String   @unique
  vendor       String
  status       String   @default("ordered") // ordered, partial, received, cancelled
  orderDate    DateTime @default(now())
  expectedDate DateTime?
  receivedDate DateTime?
  totalAmount  Float?
  notes        String?
  createdAt    DateTime @default(now())
}

// ─── PRODUCTION ──────────────────────────────────────────

model WorkCenter {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  type        String   // prepress, press, die-cutting, gluing, qa, shipping
  capacity    Int?     // jobs per day
  isActive    Boolean  @default(true)
  machines    Machine[]
  schedules   ProductionSchedule[]
  createdAt   DateTime @default(now())
}

model Machine {
  id           String     @id @default(cuid())
  workCenterId String
  workCenter   WorkCenter @relation(fields: [workCenterId], references: [id], onDelete: Cascade)
  name         String
  code         String     @unique
  type         String?
  isActive     Boolean    @default(true)
  schedules    ProductionSchedule[]
  createdAt    DateTime   @default(now())

  @@index([workCenterId])
}

model ProductionSchedule {
  id            String      @id @default(cuid())
  jobId         String
  job           Job         @relation(fields: [jobId], references: [id], onDelete: Cascade)
  workCenterId  String
  workCenter    WorkCenter  @relation(fields: [workCenterId], references: [id])
  machineId     String?
  machine       Machine?    @relation(fields: [machineId], references: [id])
  scheduledDate DateTime    @db.Date
  estimatedHours Float?
  actualHours   Float?
  status        String      @default("scheduled") // scheduled, running, complete, delayed
  notes         String?
  createdAt     DateTime    @default(now())

  @@index([jobId])
  @@index([workCenterId])
  @@index([scheduledDate])
}

// ─── SHIPPING ────────────────────────────────────────────

model Shipment {
  id            String         @id @default(cuid())
  orderId       String
  order         Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  shipmentNumber String        @unique
  carrier       String?
  trackingNumber String?
  status        ShipmentStatus @default(PREPARING)
  shipDate      DateTime?
  estimatedDelivery DateTime?
  actualDelivery DateTime?
  destination   String?
  cartons       Int?
  pallets       Int?
  weight        Float?
  isPartial     Boolean        @default(false)
  items         ShipmentItem[]
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([orderId])
}

model ShipmentItem {
  id          String   @id @default(cuid())
  shipmentId  String
  shipment    Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  description String
  quantity    Int
  createdAt   DateTime @default(now())
}

// ─── DOCUMENTS ───────────────────────────────────────────

model Document {
  id        String   @id @default(cuid())
  orderId   String?
  order     Order?   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  name      String
  type      String   // artwork, dieline, proof, po, shipping, qa, invoice, photo
  url       String
  fileSize  Int?
  uploadedBy String?
  createdAt DateTime @default(now())

  @@index([orderId])
}

// ─── COMMENTS & ACTIVITY ─────────────────────────────────

model Comment {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  content   String
  isInternal Boolean @default(true)
  createdAt DateTime @default(now())

  @@index([orderId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  orderId   String?
  order     Order?   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  details   String?
  createdAt DateTime @default(now())

  @@index([orderId])
}

// ─── JOB LINE ITEMS (multiple versions/quantities per job) ─

model JobLineItem {
  id              String   @id @default(cuid())
  jobId           String
  job             Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  productCode     String?  // e.g. "MR-30232"
  batchNumber     String?  // e.g. "7001"
  quantity        Int
  description     String
  flatSize        String?
  finishedWidth   Float?
  finishedHeight  Float?
  inkSpec         String?  // e.g. "5/0 -PROCESS"
  poNumber        String?  // e.g. "FLN-544"
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())

  @@index([jobId])
}

// ─── PRESS RUNS (multiple press entries per job) ─────────

model PressRun {
  id             String   @id @default(cuid())
  jobId          String
  job            Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  press          String   // e.g. "KOM"
  formNumber     String?  // e.g. "1", "2", "3"
  finishCount    Int?
  makeReady      Int?
  runningSize    String?  // e.g. "23X29"
  imposition     String?  // e.g. "1-Side"
  numberUp       Int?
  inkSpec        String?  // e.g. "5/0"
  firstPassCount Int?
  finalPressCount Int?
  pressmanInitials String?
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())

  @@index([jobId])
}

// ─── OUTSIDE PURCHASES ───────────────────────────────────

model PurchaseFlag {
  id           String   @id @default(cuid())
  jobId        String
  job          Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  category     String   // paper, ink, cutting_die, foil_die, outside_service, other
  description  String
  vendor       String?
  estimatedCost Float?
  status       String   @default("needed") // needed, ordered, received
  poNumber     String?
  orderedDate  DateTime?
  receivedDate DateTime?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([jobId])
  @@index([status])
}

// ─── QUOTES ──────────────────────────────────────────────

enum QuoteStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
  CONVERTED
  ARCHIVED
}

enum ProductType {
  FOLDING_CARTON
  COMMERCIAL_PRINT
}

model Quote {
  id            String      @id @default(cuid())
  quoteNumber   String      @unique
  companyId     String?
  customerName  String
  contactName   String?
  contactEmail  String?
  productType   ProductType @default(FOLDING_CARTON)
  productName   String
  description   String?
  quantity      Int
  unitPrice     Float       @default(0)
  totalPrice    Float       @default(0)
  status        QuoteStatus @default(DRAFT)
  validUntil    DateTime?
  notes         String?
  customerNotes String?     // customer-facing notes shown on the quote PDF/email
  specs         String?     // JSON string for dimensions, paper, colors, etc.
  createdBy     String?
  convertedJobId String?
  quoteRequestId String?    // Link back to originating quote request for pass-through of full QR detail
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([status])
  @@index([quoteNumber])
}

// ─── PLANT STANDARDS ────────────────────────────────────

model PlantStandard {
  id                    String   @id @default(cuid())

  // Pre-press rates ($/hr)
  markupLayoutRate      Float    @default(55)
  artworkRate           Float    @default(60)
  typesettingRate       Float    @default(55)
  proofingRate          Float    @default(38.50)
  scanningRate          Float    @default(75)

  // Per-unit proof pricing (Phase 1 — Mary's feedback)
  // Replaces the unwired Sherpa/Dylux/Matchprint count fields with
  // simple per-proof pricing for high-res 1-sided and low-res 2-sided.
  hiResProofCost        Float    @default(30)    // per high-res 1-sided proof
  lowResProofCost       Float    @default(12)    // per low-res 2-sided proof
  imposeTimePerFormMin  Float    @default(15)    // prepress impose time per form (minutes)

  // Per-unit finishing times (Phase 1 — for quantitative finishing inputs
  // like "# of cuts", "# of folds", "# of drill holes" that replace
  // difficulty dials with actual counts)
  cutTimePerCutSec      Float    @default(8)     // paper cut on trimmer
  foldTimePerFoldSec    Float    @default(2)     // per fold per sheet (folder runs ~1800/hr at 2 folds)
  drillTimePerHoleSec   Float    @default(4)     // per drill hole per sheet

  // Phase II Part 2 — Darrin's press/cut/finishing refinements
  // Coverage-driven press speed: solids run ~8-9k sph (vs. light coverage
  // at 10-20k on ideal paper). When coverage exceeds the threshold, press
  // speed caps at solidCoveragePressSpeed.
  solidCoveragePressSpeed     Int      @default(8500)
  heavyCoverageThresholdPct   Float    @default(60)
  // Heavy-board cap (Mary 4/24/26): 28pt+ stocks max out at 4,100 SPH on
  // press regardless of config — Rob has to run them slow every time.
  boardThicknessCapInches     Float    @default(0.028)
  boardThicknessMaxSpeed      Int      @default(4100)

  // Digital click charges (Mary 4/24/26 — three sheet-size tiers × five
  // ink configs, plus per-side variable data + VD setup hourly).
  // Tier 1: 8.5×11 to 13×19   Tier 2: 13×19.3 to 13×30   Tier 3: 13×30.1 to 13×35.4
  digitalClickT1_1_0          Float    @default(0.06825)  // 1/0 Black
  digitalClickT1_1_1          Float    @default(0.084)    // 1/1 Black
  digitalClickT1_4_0          Float    @default(0.189)    // 4/0 Process
  digitalClickT1_4_1          Float    @default(0.265)    // 4/1 Process/Black
  digitalClickT1_4_4          Float    @default(0.378)    // 4/4 Process
  digitalClickT1_VD           Float    @default(0.13545)  // VD per side, additive
  digitalClickT2_1_0          Float    @default(0.1024)
  digitalClickT2_1_1          Float    @default(0.126)
  digitalClickT2_4_0          Float    @default(0.2835)
  digitalClickT2_4_1          Float    @default(0.386)
  digitalClickT2_4_4          Float    @default(0.567)
  digitalClickT2_VD           Float    @default(0.203175)
  digitalClickT3_1_0          Float    @default(0.137)
  digitalClickT3_1_1          Float    @default(0.168)
  digitalClickT3_4_0          Float    @default(0.378)
  digitalClickT3_4_1          Float    @default(0.515)
  digitalClickT3_4_4          Float    @default(0.756)
  digitalClickT3_VD           Float    @default(0.2709)
  digitalVDSetupRate          Float    @default(65)       // $/hr for VD setup + list maintenance
  // Tier breakpoints (longest dimension of the run sheet, in inches)
  digitalTier1MaxLength       Float    @default(19)       // up to 13×19
  digitalTier2MaxLength       Float    @default(30)       // 13×19.3 to 13×30
  digitalTier3MaxLength       Float    @default(35.4)     // 13×30.1 to 13×35.4
  // Cut lift model: cutter processes a lift (stack) at a time, limited by
  // lift height. Standard lift ~6 inches. Lifts = ceil(sheets × caliper / 6).
  cutLiftHeightInches         Float    @default(6)
  // Score/perf pricing via scorePerfRate ($37.50/hr) and scorePerfPerHour
  // (4500/hr). Perf rule is premium because the rule costs more to replace.
  perfRulePremiumMultiplier   Float    @default(1.5)
  // Padding (hand bindery rate from handBinderyRate)
  paddingSheetsPerHour        Int      @default(1000)
  // Banding/wrapping — 14" x 4770' 55-gauge film at ~$0.057/ft; minor labor
  // per bundle at hand bindery rate.
  wrapFilmCostPerFoot         Float    @default(0.057)
  wrapLaborMinutesPerBundle   Float    @default(1)

  // Plate making
  plateMakingRate       Float    @default(22)
  plateSetupMinutes     Float    @default(5)
  plateExposureMinutes  Float    @default(3)

  // Paper handling
  paperCuttingRate      Float    @default(32)

  // Ink costs ($/lb)
  inkBlackPerLb         Float    @default(10.81)
  inkColorPerLb         Float    @default(10.81)
  inkPmsPerLb           Float    @default(19.50)
  inkPmsBlackPerLb      Float    @default(39.50)
  inkMetallicPerLb      Float    @default(19.50)
  inkAqueousPerLb       Float    @default(18.00)
  inkVarnishPerLb       Float    @default(5.50)

  // Ink coverage (thousands of sq inches per lb)
  coverageBlackUncoated Float    @default(275)
  coverageBlackCoated   Float    @default(425)
  coverageColorUncoated Float    @default(275)
  coverageColorCoated   Float    @default(425)

  // Ink usage on press (lbs)
  inkBlackSetupLbs      Float    @default(0.50)
  inkColorSetupLbs      Float    @default(0.50)

  // Ink mixing
  inkMixFirstLbMinutes  Float    @default(10)
  inkMixAddlLbMinutes   Float    @default(3)
  inkMixRate            Float    @default(16)

  // Markup percentages
  markupPaper           Float    @default(22)
  markupMaterial        Float    @default(22)
  markupLabor           Float    @default(63)
  markupOutside         Float    @default(30)

  // Bindery rates ($/hr)
  trimmingRate          Float    @default(45)
  trimmerSetupMinutes   Float    @default(13)
  drillingRate          Float    @default(35)
  drillingSetupMinutes  Float    @default(30)
  handBinderyRate       Float    @default(22.50)
  paddingRate           Float    @default(18)
  wrappingRate          Float    @default(35)
  handCollatingRate     Float    @default(22.50)

  // Folders ($/hr)
  folder1Name           String   @default("Baum-26x40")
  folder1Rate           Float    @default(48)
  folder1SetupMinutes   Float    @default(20)
  folder2Name           String   @default("Small Baum")
  folder2Rate           Float    @default(35)
  folder2SetupMinutes   Float    @default(30)
  folder3Name           String   @default("Stahl")
  folder3Rate           Float    @default(48)
  folder3SetupMinutes   Float    @default(20)

  // Saddle stitching ($/hr)
  saddleStitch1Name     String   @default("Mueller")
  saddleStitch1Rate     Float    @default(95)
  saddleStitch1Speed    Int      @default(8000)
  saddleStitch1Pockets  Int      @default(7)
  saddleStitch2Name     String   @default("Rosback")
  saddleStitch2Rate     Float    @default(55)
  saddleStitch2Speed    Int      @default(3500)
  saddleStitch2Pockets  Int      @default(1)

  // Score/Perf
  scorePerfRate         Float    @default(37.50)
  scorePerfPerHour      Int      @default(4500)
  scorePerfSetupMinutes Float    @default(30)

  // Delivery
  deliveryRate          Float    @default(60)
  deliveryAvgMinutes    Float    @default(30)

  // Packing
  packingRate           Float    @default(15)
  skidCost              Float    @default(5.00)
  carton1Name           String   @default("11.25x8.75x10")
  carton1Cost           Float    @default(0.93)
  carton1MaxLbs         Float    @default(25)
  carton2Name           String   @default("11x9x10")
  carton2Cost           Float    @default(0.75)
  carton2MaxLbs         Float    @default(30)
  carton3Name           String   @default("LTHD BOX")
  carton3Cost           Float    @default(0.52)
  carton3MaxLbs         Float    @default(5)

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model Press {
  id                    String        @id @default(cuid())
  pressNumber           Int           @unique
  name                  String
  pressType             String        @default("Sheet Fed Offset")
  costPerHour           Float
  helperCostPerHour     Float         @default(0)
  blanketCost           Float         @default(0)
  maxSheetWidth         Float
  maxSheetHeight        Float
  minSheetWidth         Float         @default(0)
  minSheetHeight        Float         @default(0)
  plateChangeMinutes    Float         @default(15)
  inkChangeMinutes      Float         @default(10)
  canPrintSolids        Boolean       @default(true)
  minFormMinutes        Float         @default(10)
  isActive              Boolean       @default(true)

  configurations        PressConfig[]
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
}

model PressConfig {
  id                         String   @id @default(cuid())
  pressId                    String
  press                      Press    @relation(fields: [pressId], references: [id], onDelete: Cascade)
  configNumber               Int
  name                       String
  setupMinutes               Float    @default(5)
  speedUncoated              Int
  speedCoated                Int
  gripperEighths             Float    @default(3)
  numColors                  Int
  coatingType                String?
  coatingCostPerLb           Float    @default(0)
  perfectorColorsPerSide     Float    @default(0)
  addToHourlyRate            Float    @default(0)
  numHelpers                 Int      @default(0)

  // Plate info
  maxImpressions             Int      @default(0)
  plateCost                  Float
  plateDevelopMinutes        Float    @default(5)
  strippingMaterialCost      Float    @default(2)

  // Waste - setup sheets
  setupWasteUncoated         Int      @default(200)
  setupWasteCoated           Int      @default(200)
  plateChangeWasteUncoated   Int      @default(100)
  plateChangeWasteCoated     Int      @default(100)

  // Waste curves as JSON: [{"min":1,"max":2500,"pctFirst":5.0,"pctAddl":0.0}, ...]
  wasteCurveUncoated         String   @default("[]")
  wasteCurveCoated           String   @default("[]")

  isActive                   Boolean  @default(true)
  createdAt                  DateTime @default(now())

  @@unique([pressId, configNumber])
  @@index([pressId])
}

// ─── TIME TRACKING ───────────────────────────────────────

model TimeEntry {
  id          String    @id @default(cuid())
  jobId       String
  job         Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  department  String
  startTime   DateTime
  endTime     DateTime?
  duration    Int?      // seconds
  notes       String?
  createdAt   DateTime  @default(now())

  @@index([jobId])
  @@index([userId])
  @@index([department])
}

// ─── INVOICES & PAYMENTS ─────────────────────────────────

model Invoice {
  id              String    @id @default(cuid())
  invoiceNumber   String    @unique
  orderId         String?
  jobId           String?
  companyId       String?
  customerName    String
  contactEmail    String?
  description     String?
  subtotal        Float
  taxRate         Float     @default(7)
  taxAmount       Float
  total           Float
  depositPercent  Float     @default(50)
  depositAmount   Float
  depositPaid     Boolean   @default(false)
  depositPaidAt   DateTime?
  balancePaid     Boolean   @default(false)
  balancePaidAt   DateTime?
  status          String    @default("pending") // pending, deposit_paid, paid, overdue, cancelled
  stripeSessionId String?
  stripePaymentId String?
  dueDate         DateTime?
  notes           String?
  createdBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status])
  @@index([companyId])
  @@index([invoiceNumber])
}

// ─── QUOTE REQUESTS (Sales/CSR intake for estimating) ────

model QuoteRequest {
  id                String   @id @default(cuid())
  requestNumber     String   @unique
  status            String   @default("pending") // pending, estimating, completed, cancelled
  dateNeeded        DateTime?
  jobType           String?  // new, exact_reprint, reprint_with_changes
  pickupJobNumber   String?  // previous job number for reprints
  customerName      String
  companyId         String?
  productType       String?  // komori, digital, letterpress, bindery, vendor
  descriptionType   String?  // flyer, postcard, brochure, book, etc.
  jobTitle          String?
  // Legacy quantity fields kept for backwards compat; new requests use lineItems
  quantity1         Int?
  quantity2         Int?
  quantity3         Int?
  quantity4         Int?
  quantity5         Int?
  pages             Int?
  coverType         String?  // self_cover, plus_cover
  orientation       String?  // portrait, landscape
  // Proofs
  lowResProofs      Int?
  hiResProofs       Int?
  // Colors
  colorsSide1       String?
  colorsSide2       String?
  // Coatings (expanded per Mary's form)
  coatingSide1      String?
  coatingSide2      String?
  floodUv           Boolean  @default(false)
  spotUv            Boolean  @default(false)
  uvSides           String?  // "1" or "2"
  floodLedUv        Boolean  @default(false)
  spotLedUv         Boolean  @default(false)
  ledUvSides        String?
  aqueous           Boolean  @default(false)
  drytrap           Boolean  @default(false)
  customColorCoatingNotes String?
  // Sizes (defaults for all lines; lineItems can override)
  flatWidth         Float?
  flatHeight        Float?
  finishedWidth     Float?
  finishedHeight    Float?
  finishedDepth     Float?
  hasBleeds         Boolean  @default(false)
  // Paper
  paperWeight       String?
  paperDescription  String?
  paperType         String?  // text, cover
  // Folding / scoring / perf
  foldType          String?
  score             Boolean  @default(false)
  perf              Boolean  @default(false)
  // Die / foil / emboss
  dieCut            Boolean  @default(false)
  existingDieNumber String?
  numPockets        Int?
  dieVHSize         String?  // "V" or "H" + size
  foil              String?  // spec description
  foilIsNew         Boolean  @default(false)
  emboss            String?
  embossIsNew       Boolean  @default(false)
  // Bindery
  saddleStitch      Boolean  @default(false)
  cornerStitch      Boolean  @default(false)
  perfectBind       Boolean  @default(false)
  plasticCoil       String?
  wireO             String?
  gbc               String?
  caseBind          String?
  // Finishing
  lamination        String?
  drill             Boolean  @default(false)
  bandIn            String?
  wrapIn            String?
  padIn             String?
  ncrPad            Boolean  @default(false)
  numbering         String?
  punch             Boolean  @default(false)
  roundCorner       Boolean  @default(false)
  // Mailing
  mailingServices   String?
  waferSeal         Boolean  @default(false)
  waferSealTabs     Int?
  waferSealLocation String?
  // Generic finishing fallback
  finishing         String?  // JSON array of finishing operations (legacy)
  // Artwork
  artworkUrl        String?
  artworkFileName   String?
  artworkIsNew      Boolean  @default(true)
  artworkNotes      String?
  // Notes + delivery
  specialInstructions String?
  vendorName        String?
  deliveryInstructions String?
  // Tracking
  submittedBy       String
  submittedByName   String
  estimatedBy       String?
  convertedQuoteId  String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  lineItems         QuoteRequestLineItem[]

  @@index([status])
  @@index([submittedBy])
}

// Per-SKU/version breakdown on a quote request — supports multi-version orders
// (e.g., Scar Heal with 2oz / 4oz / 8oz boxes each with own qty/die).
model QuoteRequestLineItem {
  id               String       @id @default(cuid())
  quoteRequestId   String
  quoteRequest     QuoteRequest @relation(fields: [quoteRequestId], references: [id], onDelete: Cascade)
  sortOrder        Int          @default(0)
  version          String       // label, e.g., "2oz box", "Side A", "English"
  quantity         Int          @default(0)
  // Optional per-line overrides of request-level defaults
  flatWidth        Float?
  flatHeight       Float?
  finishedWidth    Float?
  finishedHeight   Float?
  finishedDepth    Float?
  dieNumber        String?
  dieIsNew         Boolean      @default(false)
  notes            String?

  @@index([quoteRequestId])
}

// ─── PAPER USAGE & VENDOR PURCHASES ──────────────────────

model PaperUsage {
  id          String    @id @default(cuid())
  itemNumber  String?
  jobNumber   String?
  wipStatus   String?
  date        DateTime?
  source      String?
  direction   String?
  quantityIn  Int       @default(0)
  quantityOut Int       @default(0)
  weight      String?
  coating     String?
  stockType   String?
  size        String?
  description String?
  pricePerM   Float?
  totalOut    Float?
  totalIn     Float?
  createdAt   DateTime  @default(now())

  @@index([jobNumber])
  @@index([date])
}

model VendorPurchase {
  id              String    @id @default(cuid())
  itemNumber      String?
  jobNumber       String?
  wipStatus       String?
  date            DateTime?
  vendor          String?
  quantity        Int       @default(0)
  weight          String?
  size            String?
  description     String?
  pricePerM       Float?
  total           Float?
  quotedPricePerM Float?
  quotedTotal     Float?
  savings         Float?
  createdAt       DateTime  @default(now())

  @@index([vendor])
  @@index([date])
  @@index([jobNumber])
}

// ─── HELP DESK ───────────────────────────────────────────

model HelpTicket {
  id          String   @id @default(cuid())
  title       String
  description String
  category    String   @default("bug") // bug, feature, question, other
  priority    String   @default("normal") // low, normal, high, urgent
  status      String   @default("open") // open, in_progress, resolved, closed
  page        String?  // which page the issue is on
  screenshot  String?  // URL or description
  submittedBy String
  submittedByName String
  submittedByRole String
  resolvedAt  DateTime?
  resolvedBy  String?
  resolution  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([submittedBy])
}

// ─── CUTTING DIES ────────────────────────────────────────

model CuttingDie {
  id              String   @id @default(cuid())
  dieNumber       String   @unique
  originalJobNumber String?
  customerName    String?
  item            String?
  description     String?
  length          Float?
  width           Float?
  height          Float?
  notes           String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  @@index([customerName])
  @@index([dieNumber])
}

// ─── ALERTS ──────────────────────────────────────────────

model Alert {
  id         String        @id @default(cuid())
  jobId      String?
  job        Job?          @relation(fields: [jobId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?         @relation(fields: [userId], references: [id])
  type       AlertType
  severity   AlertSeverity @default(WARNING)
  message    String
  isRead     Boolean       @default(false)
  resolvedAt DateTime?
  createdAt  DateTime      @default(now())

  @@index([jobId])
  @@index([userId])
}
